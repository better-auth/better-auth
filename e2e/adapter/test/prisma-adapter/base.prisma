generator client {
  provider = "prisma-client"
  output   = "./.tmp/prisma-client-base"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String     @id
  name          String
  email         String
  emailVerified Boolean    @default(false)
  image         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @default(now()) @updatedAt
  sessions      Session[]
  identities    Identity[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([token])
  @@map("session")
}

model Identity {
  id                String    @id
  issuer            String
  providerAccountId String
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  accounts          Account[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([issuer, providerAccountId])
  @@map("identity")
}

model Account {
  id                    String    @id
  identityId            String
  identity              Identity  @relation(fields: [identityId], references: [id], onDelete: Restrict)
  providerId            String
  providerInstanceId    String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([identityId, providerInstanceId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}
