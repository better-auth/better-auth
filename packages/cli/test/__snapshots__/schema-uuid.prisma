
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  name             String
  email            String
  emailVerified    Boolean           @default(false)
  image            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  username         String?
  displayUsername  String?
  sessions         Session[]
  accounts         Account[]
  signinattempts   SignInAttempt[]
  twofactormethods TwoFactorMethod[]
  trusteddevices   TrustedDevice[]

  @@unique([email])
  @@unique([username])
  @@map("user")
}

model Session {
  id        String   @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amr       Json

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  accountId             String
  providerId            String
  userId                String    @db.Uuid
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model SignInAttempt {
  id                  String    @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  userId              String    @db.Uuid
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt           DateTime
  rememberMe          Boolean?
  amr                 Json
  failedVerifications Int       @default(0)
  lockedAt            DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@map("signInAttempt")
}

model TwoFactorMethod {
  id                     String                  @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  userId                 String                  @db.Uuid
  user                   User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind                   String
  label                  String?
  verifiedAt             DateTime?
  lastUsedAt             DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  twofactortotp          TwoFactorTotp?
  twofactorrecoverycodes TwoFactorRecoveryCode[]

  @@index([userId])
  @@index([kind])
  @@index([verifiedAt])
  @@map("twoFactorMethod")
}

model TwoFactorTotp {
  id              String          @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  methodId        String          @db.Uuid
  twofactormethod TwoFactorMethod @relation(fields: [methodId], references: [id], onDelete: Cascade)
  secret          String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([methodId])
  @@map("twoFactorTotp")
}

model TwoFactorRecoveryCode {
  id              String          @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  methodId        String          @db.Uuid
  twofactormethod TwoFactorMethod @relation(fields: [methodId], references: [id], onDelete: Cascade)
  codeHash        String
  usedAt          DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([methodId])
  @@index([codeHash])
  @@map("twoFactorRecoveryCode")
}

model TrustedDevice {
  id            String    @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  userId        String    @db.Uuid
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lookupKeyHash String
  label         String?
  userAgent     String?
  lastUsedAt    DateTime?
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([lookupKeyHash])
  @@index([userId])
  @@index([expiresAt])
  @@map("trustedDevice")
}
