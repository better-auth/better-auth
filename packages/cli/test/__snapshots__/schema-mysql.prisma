
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id
  name             String            @db.Text
  email            String
  emailVerified    Boolean           @default(false)
  image            String?           @db.Text
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  username         String?
  displayUsername  String?           @db.Text
  sessions         Session[]
  accounts         Account[]
  signinattempts   SignInAttempt[]
  twofactormethods TwoFactorMethod[]
  trusteddevices   TrustedDevice[]

  @@unique([email])
  @@unique([username])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?  @db.Text
  userAgent String?  @db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amr       String

  @@unique([token])
  @@index([userId(length: 191)])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String    @db.Text
  providerId            String    @db.Text
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?   @db.Text
  password              String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId(length: 191)])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String   @db.Text
  value      String   @db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier(length: 191)])
  @@map("verification")
}

model SignInAttempt {
  id                  String    @id
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt           DateTime
  rememberMe          Boolean?
  amr                 String
  failedVerifications Int       @default(0)
  lockedAt            DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([userId(length: 191)])
  @@index([expiresAt])
  @@map("signInAttempt")
}

model TwoFactorMethod {
  id                     String                  @id
  userId                 String
  user                   User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind                   String                  @db.Text
  label                  String?                 @db.Text
  verifiedAt             DateTime?
  lastUsedAt             DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  twofactortotp          TwoFactorTotp?
  twofactorrecoverycodes TwoFactorRecoveryCode[]

  @@index([userId(length: 191)])
  @@index([kind(length: 191)])
  @@index([verifiedAt])
  @@map("twoFactorMethod")
}

model TwoFactorTotp {
  id              String          @id
  methodId        String
  twofactormethod TwoFactorMethod @relation(fields: [methodId], references: [id], onDelete: Cascade)
  secret          String          @db.Text
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([methodId])
  @@map("twoFactorTotp")
}

model TwoFactorRecoveryCode {
  id              String          @id
  methodId        String
  twofactormethod TwoFactorMethod @relation(fields: [methodId], references: [id], onDelete: Cascade)
  codeHash        String          @db.Text
  usedAt          DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([methodId(length: 191)])
  @@index([codeHash(length: 191)])
  @@map("twoFactorRecoveryCode")
}

model TrustedDevice {
  id            String    @id
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lookupKeyHash String
  label         String?   @db.Text
  userAgent     String?   @db.Text
  lastUsedAt    DateTime?
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([lookupKeyHash])
  @@index([userId(length: 191)])
  @@index([expiresAt])
  @@map("trustedDevice")
}
