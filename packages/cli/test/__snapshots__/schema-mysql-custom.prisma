
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                @id
  name                 String                @db.Text
  email                String
  emailVerified        Boolean               @default(false)
  image                String?               @db.Text
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  twoFactorEnabled     Boolean?              @default(false)
  username             String?
  displayUsername      String?               @db.Text
  sessions             Session[]
  accounts             Account[]
  twofactors           TwoFactor[]
  members              Member[]
  workspaceinvitations WorkspaceInvitation[]
  teammembers          TeamMember[]

  @@unique([email])
  @@unique([username])
  @@map("user")
}

model Session {
  id                   String   @id
  expiresAt            DateTime
  token                String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  ipAddress            String?  @db.Text
  userAgent            String?  @db.Text
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganizationId String?  @db.Text
  activeTeamId         String?  @db.Text

  @@unique([token])
  @@index([userId(length: 191)])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String    @db.Text
  providerId            String    @db.Text
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?   @db.Text
  password              String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId(length: 191)])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String   @db.Text
  value      String   @db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier(length: 191)])
  @@map("verification")
}

model TwoFactor {
  id          String @id
  secret      String @db.Text
  backupCodes String @db.Text
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([secret(length: 191)])
  @@index([userId(length: 191)])
  @@map("twoFactor")
}

model Workspace {
  id                   String                @id
  name                 String                @db.Text
  slug                 String
  logo                 String?               @db.Text
  createdAt            DateTime
  metadata             String?               @db.Text
  members              Member[]
  workspaceinvitations WorkspaceInvitation[]
  organizationroles    OrganizationRole[]
  teams                Team[]

  @@unique([slug])
  @@map("workspace")
}

model Member {
  id                      String                   @id
  organizationId          String
  workspace               Workspace                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId                  String
  user                    User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt               DateTime
  memberorganizationroles MemberOrganizationRole[]

  @@index([organizationId(length: 191)])
  @@index([userId(length: 191)])
  @@map("member")
}

model WorkspaceInvitation {
  id                String    @id
  organizationId    String
  workspace         Workspace @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email             String    @db.Text
  organizationRoles Json?
  teamRoles         Json?
  teamId            String?   @db.Text
  status            String    @db.Text
  expiresAt         DateTime
  createdAt         DateTime  @default(now())
  inviterId         String
  user              User      @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId(length: 191)])
  @@index([email(length: 191)])
  @@map("workspaceInvitation")
}

model OrganizationRole {
  id             String    @id
  organizationId String
  workspace      Workspace @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           String    @db.Text
  name           String    @db.Text
  description    String?   @db.Text
  isBuiltIn      Boolean   @default(false)
  permissions    Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime? @updatedAt

  @@index([organizationId(length: 191)])
  @@index([type(length: 191)])
  @@map("organizationRole")
}

model TeamRole {
  id          String    @id
  teamId      String
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  type        String    @db.Text
  name        String    @db.Text
  description String?   @db.Text
  isBuiltIn   Boolean   @default(false)
  permissions Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt

  @@index([teamId(length: 191)])
  @@index([type(length: 191)])
  @@map("teamRole")
}

model MemberOrganizationRole {
  id             String   @id
  memberId       String
  member         Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  organizationId String   @db.Text
  role           String   @db.Text
  createdAt      DateTime @default(now())

  @@index([memberId(length: 191)])
  @@index([organizationId(length: 191)])
  @@index([role(length: 191)])
  @@map("memberOrganizationRole")
}

model MemberTeamRole {
  id             String     @id
  team_member_id String
  teammember     TeamMember @relation(fields: [team_member_id], references: [id], onDelete: Cascade)
  teamId         String     @db.Text
  role           String     @db.Text
  createdAt      DateTime   @default(now())

  @@index([team_member_id(length: 191)])
  @@index([teamId(length: 191)])
  @@index([role(length: 191)])
  @@map("memberTeamRole")
}

model Team {
  id             String       @id
  name           String       @db.Text
  organizationId String
  workspace      Workspace    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime
  updatedAt      DateTime?    @updatedAt
  teamroles      TeamRole[]
  teammembers    TeamMember[]

  @@index([organizationId(length: 191)])
  @@map("team")
}

model TeamMember {
  id              String           @id
  teamId          String
  team            Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime?
  memberteamroles MemberTeamRole[]

  @@index([teamId(length: 191)])
  @@index([userId(length: 191)])
  @@map("teamMember")
}
