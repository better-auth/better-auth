
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Users {
  id            String       @id
  name          String
  email         String
  emailVerified Boolean      @default(false)
  image         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  sessions      Sessions[]
  identities    Identities[]

  @@unique([email])
  @@map("users")
}

model Sessions {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  users     Users    @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([token])
  @@index([userId])
  @@map("sessions")
}

model Identities {
  id                String     @id
  issuer            String
  providerAccountId String
  userId            String
  users             Users      @relation(fields: [userId], references: [id], onDelete: Restrict)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  accounts          Accounts[]

  @@unique([issuer, providerAccountId], map: "identities_issuer_providerAccountId_uidx")
  @@index([userId])
  @@map("identities")
}

model Accounts {
  id                    String     @id
  identityId            String
  identities            Identities @relation(fields: [identityId], references: [id], onDelete: Restrict)
  providerId            String
  providerInstanceId    String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@unique([identityId, providerInstanceId], map: "accounts_identityId_providerInstanceId_uidx")
  @@map("accounts")
}

model Verifications {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}
