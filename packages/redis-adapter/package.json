{
  "name": "@better-auth/redis-adapter",
  "version": "1.0.0",
  "description": "Redis adapter for better auth",
  "type": "module",
  "license": "MIT",
  "homepage": "https://www.better-auth.com/docs/storage",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/better-auth/better-auth.git",
    "directory": "packages/redis-adapter"
  },
  "keywords": [
    "auth",
    "redis",
    "adapter",
    "typescript",
    "better-auth"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint:package": "publint run --strict --pack false",
    "lint:types": "attw --profile esm-only --pack .",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "dev-source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "peerDependencies": {
    "@better-auth/core": "workspace:^",
    "ioredis": "^5.0.0"
  },
  "devDependencies": {
    "@better-auth/core": "workspace:*",
    "@types/node": "^25.3.2",
    "ioredis": "^5.9.3",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:vitest"
  },
  "dependencies": {
    "redis": "^5.12.1"
  }
}
