{
  "name": "@better-auth/organization",
  "version": "1.5.0-beta.13",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/better-auth/better-auth.git",
    "directory": "packages/organization"
  },
  "keywords": [
    "auth",
    "organization",
    "multi-tenant",
    "teams",
    "rbac"
  ],
  "publishConfig": {
    "access": "public"
  },
  "module": "dist/index.mjs",
  "description": "Organization plugin for Better Auth",
  "scripts": {
    "test": "vitest",
    "coverage": "vitest run --coverage --coverage.provider=istanbul",
    "lint:package": "publint run --strict",
    "lint:types": "attw --profile esm-only --pack .",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --project tsconfig.json"
  },
  "exports": {
    ".": {
      "dev-source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./client": {
      "dev-source": "./src/client/index.ts",
      "types": "./dist/client.d.mts",
      "default": "./dist/client.mjs"
    },
    "./access": {
      "dev-source": "./src/access/index.ts",
      "types": "./dist/access.d.mts",
      "default": "./dist/access.mjs"
    },
    "./teams/client": {
      "dev-source": "./src/addons/teams/client.ts",
      "types": "./dist/teams/client.d.mts",
      "default": "./dist/teams/client.mjs"
    },
    "./teams": {
      "dev-source": "./src/addons/teams/index.ts",
      "types": "./dist/teams.d.mts",
      "default": "./dist/teams.mjs"
    },
    "./dynamic-access-control/client": {
      "dev-source": "./src/addons/dynamic-access-control/client.ts",
      "types": "./dist/dynamic-access-control/client.d.mts",
      "default": "./dist/dynamic-access-control/client.mjs"
    },
    "./dynamic-access-control": {
      "dev-source": "./src/addons/dynamic-access-control/index.ts",
      "types": "./dist/dynamic-access-control.d.mts",
      "default": "./dist/dynamic-access-control.mjs"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.mts"
      ],
      "client": [
        "./dist/client.d.mts"
      ],
      "access": [
        "./dist/access.d.mts"
      ],
      "teams/client": [
        "./dist/teams/client.d.mts"
      ],
      "teams": [
        "./dist/teams.d.mts"
      ],
      "dynamic-access-control/client": [
        "./dist/dynamic-access-control/client.d.mts"
      ],
      "dynamic-access-control": [
        "./dist/dynamic-access-control.d.mts"
      ]
    }
  },
  "dependencies": {
    "defu": "^6.1.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/core": "workspace:*",
    "better-call": "catalog:",
    "tsdown": "catalog:"
  },
  "peerDependencies": {
    "@better-auth/core": "workspace:*",
    "better-auth": "workspace:*",
    "better-call": "catalog:"
  }
}
