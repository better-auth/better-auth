{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["esnext", "dom", "dom.iterable"],
    "jsx": "react-jsx",
    "jsxImportSource": "@better-auth/ui",
    "outDir": "${configDir}/node_modules/.cache/ts/test-out",
    "tsBuildInfoFile": "${configDir}/node_modules/.cache/ts/test-tsbuildinfo"
