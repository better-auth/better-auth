{
  "name": "@better-auth/test-utils",
  "version": "1.5.1-beta.3",
  "description": "Testing utilities for Better Auth adapter development",
  "type": "module",
  "license": "MIT",
  "homepage": "https://www.better-auth.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/better-auth/better-auth.git",
    "directory": "packages/test-utils"
  },
  "keywords": [
    "auth",
    "testing",
    "typescript",
    "better-auth"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "files": [
    "dist"
  ],
  "exports": {
    "./adapter": {
      "dev-source": "./src/adapter/index.ts",
      "default": "./dist/adapter.js",
      "types": "./dist/adapter.d.ts"
    }
  },
  "devDependencies": {
    "@better-auth/core": "workspace:*",
    "better-auth": "workspace:*",
    "tsup": "catalog:",
    "vitest": "catalog:vitest"
  },
  "peerDependencies": {
    "@better-auth/core": "workspace:*",
    "better-auth": "workspace:*",
    "vitest": "catalog:vitest"
  }
}
