{
  "name": "@better-auth/test-utils",
  "version": "1.5.0-beta.17",
  "type": "module",
  "description": "Test utilities for Better Auth",
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "devDependencies": {
    "tsdown": "catalog:"
  },
  "peerDependencies": {
    "@better-auth/core": "workspace:*",
    "better-auth": "workspace:*"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/better-auth/better-auth.git",
    "directory": "packages/test-utils"
  },
  "keywords": [
    "auth",
    "test",
    "typescript",
    "better-auth"
  ],
  "license": "MIT"
}