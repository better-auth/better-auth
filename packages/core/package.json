{
  "name": "@better-auth/core",
  "version": "1.6.7",
  "description": "The most comprehensive authentication framework for TypeScript.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://www.better-auth.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/better-auth/better-auth.git",
    "directory": "packages/core"
  },
  "keywords": [
    "auth",
    "core",
    "typescript",
    "better-auth"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "postbuild": "node scripts/env.ts",
    "dev": "tsc --build tsconfig.build.json --watch",
    "typecheck": "tsc --build tsconfig.json",
    "lint:package": "publint run --strict --pack false",
    "lint:types": "attw --profile esm-only --pack .",
    "test": "vitest",
    "coverage": "vitest run --coverage --coverage.provider=istanbul"
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "dev-source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./api": {
      "dev-source": "./src/api/index.ts",
      "types": "./dist/api/index.d.ts",
      "default": "./dist/api/index.js"
    },
    "./async_hooks": {
      "dev-source": "./src/async_hooks/index.ts",
      "types": "./dist/async_hooks/index.d.ts",
      "node": "./dist/async_hooks/index.js",
      "deno": "./dist/async_hooks/index.js",
      "bun": "./dist/async_hooks/index.js",
      "edge": "./dist/async_hooks/pure.index.js",
      "workerd": "./dist/async_hooks/index.js",
      "browser": "./dist/async_hooks/pure.index.js",
      "default": "./dist/async_hooks/index.js"
    },
    "./context": {
      "dev-source": "./src/context/index.ts",
      "types": "./dist/context/index.d.ts",
      "default": "./dist/context/index.js"
    },
    "./env": {
      "dev-source": "./src/env/index.ts",
      "types": "./dist/env/index.d.ts",
      "default": "./dist/env/index.js"
    },
    "./error": {
      "dev-source": "./src/error/index.ts",
      "types": "./dist/error/index.d.ts",
      "default": "./dist/error/index.js"
    },
    "./utils/*": {
      "dev-source": "./src/utils/*.ts",
      "types": "./dist/utils/*.d.ts",
      "default": "./dist/utils/*.js"
    },
    "./social-providers": {
      "dev-source": "./src/social-providers/index.ts",
      "types": "./dist/social-providers/index.d.ts",
      "default": "./dist/social-providers/index.js"
    },
    "./db": {
      "dev-source": "./src/db/index.ts",
      "types": "./dist/db/index.d.ts",
      "default": "./dist/db/index.js"
    },
    "./db/adapter": {
      "dev-source": "./src/db/adapter/index.ts",
      "types": "./dist/db/adapter/index.d.ts",
      "default": "./dist/db/adapter/index.js"
    },
    "./oauth2": {
      "dev-source": "./src/oauth2/index.ts",
      "types": "./dist/oauth2/index.d.ts",
      "default": "./dist/oauth2/index.js"
    },
    "./instrumentation": {
      "dev-source": "./src/instrumentation/index.ts",
      "types": "./dist/instrumentation/index.d.ts",
      "node": "./dist/instrumentation/index.js",
      "deno": "./dist/instrumentation/index.js",
      "bun": "./dist/instrumentation/index.js",
      "edge": "./dist/instrumentation/pure.index.js",
      "workerd": "./dist/instrumentation/index.js",
      "browser": "./dist/instrumentation/pure.index.js",
      "default": "./dist/instrumentation/index.js"
    }
  },
  "typesVersions": {
    "*": {
      ".": [
        "dist/index.d.ts"
      ],
      "api": [
        "dist/api/index.d.ts"
      ],
      "async_hooks": [
        "dist/async_hooks/index.d.ts"
      ],
      "context": [
        "dist/context/index.d.ts"
      ],
      "env": [
        "dist/env/index.d.ts"
      ],
      "error": [
        "dist/error/index.d.ts"
      ],
      "utils": [
        "dist/utils/index.d.ts"
      ],
      "utils/*": [
        "dist/utils/*.d.ts"
      ],
      "social-providers": [
        "dist/social-providers/index.d.ts"
      ],
      "db": [
        "dist/db/index.d.ts"
      ],
      "db/adapter": [
        "dist/db/adapter/index.d.ts"
      ],
      "oauth2": [
        "dist/oauth2/index.d.ts"
      ],
      "instrumentation": [
        "dist/instrumentation/index.d.ts"
      ]
    }
  },
  "dependencies": {
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "@standard-schema/spec": "^1.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/utils": "catalog:",
    "@better-fetch/fetch": "catalog:",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-base": "^1.30.0",
    "@opentelemetry/sdk-trace-node": "^1.30.0",
    "better-call": "catalog:",
    "@cloudflare/workers-types": "^4.20250121.0",
    "jose": "^6.1.3",
    "kysely": "^0.28.14",
    "nanostores": "^1.1.1"
  },
  "peerDependencies": {
    "@better-auth/utils": "catalog:",
    "@better-fetch/fetch": "catalog:",
    "@opentelemetry/api": "^1.9.0",
    "better-call": "catalog:",
    "@cloudflare/workers-types": ">=4",
    "jose": "^6.1.0",
    "kysely": "^0.28.5",
    "nanostores": "^1.0.1"
  },
  "peerDependenciesMeta": {
    "@cloudflare/workers-types": {
      "optional": true
    },
    "@opentelemetry/api": {
      "optional": true
    }
  }
}
