        "cwd": "demo/nextjs",
        "build": "better-auth-declarations",
        "prepare": [
          {
            "label": "Next.js frozen dependency install",
            "command": ["install", "--frozen-lockfile"]
          }
        ],
        "candidatePackage": "@better-auth/infra",
        "candidateWorkspacePackages": [
          "packages/better-auth",
          "packages/core",
          "packages/scim",
          "packages/sso"
